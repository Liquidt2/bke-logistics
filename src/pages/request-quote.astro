---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

// ─── OPENCLAW WEBHOOK (proxied through nginx to avoid CORS) ──────────────────
const OPENCLAW_WEBHOOK_URL = '/api/webhook';
// ─────────────────────────────────────────────────────────────────────────────
---

<BaseLayout
  title="Request a Quote"
  description="Request a freight quote from BKE Logistics LLC. Flatbed and dry van services across 48 states. Fast response, competitive rates, no hidden fees."
>
  <PageHero
    title="Request a Quote"
    subtitle="Tell us about your shipment and Harvey will personally respond with a competitive rate — typically within a few hours."
    breadcrumb={[{ label: 'Request a Quote' }]}
    eyebrow="Get a Rate"
  />

  <section class="py-16 lg:py-24 bg-bg">
    <div class="max-w-5xl mx-auto px-5 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- Sidebar -->
        <div class="lg:col-span-1">
          <h2 class="font-heading font-bold text-2xl text-text-primary mb-5">What to Expect</h2>

          <div class="space-y-5 mb-8">
            {[
              { step: '01', title: 'Submit Your Details', desc: 'Fill out the form with your pickup/delivery locations, cargo type, weight, and pickup date.' },
              { step: '02', title: 'Harvey Responds', desc: 'You\'ll hear back directly from Harvey — not a call center — with a competitive rate and carrier options.' },
              { step: '03', title: 'Book & Confirm', desc: 'Once you approve the rate, we issue a rate confirmation and get your freight scheduled.' },
              { step: '04', title: 'Load Covered', desc: 'Your freight moves. Harvey stays in communication from pickup through delivery.' },
            ].map(item => (
              <div class="flex gap-4">
                <div class="font-heading font-black text-2xl text-blue-brand/30 leading-none shrink-0 w-8">{item.step}</div>
                <div>
                  <h3 class="font-semibold text-text-primary text-sm mb-1">{item.title}</h3>
                  <p class="text-text-muted text-xs leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>

          <div class="p-4 bg-bg-card border border-white/8 rounded-2xl">
            <h3 class="font-semibold text-text-primary text-sm mb-2">Need it covered today?</h3>
            <p class="text-text-muted text-xs leading-relaxed mb-3">
              For same-day or next-day freight, call or text Harvey directly.
            </p>
            <a href="tel:+14793510393" class="text-blue-brand font-semibold text-sm hover:underline">(479) 351-0393</a>
            <div class="text-text-subtle text-xs mt-1">Call or text anytime</div>
          </div>

          <div class="mt-5 p-4 bg-bg-card border border-white/8 rounded-2xl">
            <div class="space-y-2">
              {[
                { icon: '🚛', label: 'Flatbed' },
                { icon: '📦', label: 'Dry Van' },
                { icon: '🔩', label: 'Steel & Metal' },
                { icon: '🪵', label: 'Lumber' },
                { icon: '🏗️', label: 'Construction Equipment' },
                { icon: '🛢️', label: 'Pipe & Plastic' },
              ].map(s => (
                <div class="flex items-center gap-2 text-text-muted text-xs">
                  <span>{s.icon}</span>
                  <span>{s.label}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Form -->
        <div class="lg:col-span-2">
          <div class="bg-bg-card border border-white/8 rounded-2xl overflow-hidden">
            <div class="border-b border-white/8 px-7 py-5">
              <h2 class="font-heading font-bold text-xl text-text-primary">Shipment Quote Request</h2>
              <p class="text-text-subtle text-xs mt-1">Fields marked <span class="text-blue-brand">*</span> are required</p>
            </div>

            <form id="quote-form" class="p-7 space-y-6" novalidate>

              <!-- Contact Info -->
              <div>
                <h3 class="font-heading font-bold text-sm text-text-primary uppercase tracking-wider mb-4 flex items-center gap-2">
                  <span class="w-5 h-5 rounded-full bg-blue-brand/20 flex items-center justify-center text-[10px] text-blue-brand font-bold">1</span>
                  Contact Information
                </h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label for="full_name" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">Full Name <span class="text-blue-brand">*</span></label>
                    <input type="text" id="full_name" name="full_name" required autocomplete="name"
                      class="w-full bg-bg-secondary border border-white/10 rounded-xl px-4 py-3 text-text-primary text-sm placeholder-text-subtle focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors"
                      placeholder="John Smith" />
                  </div>
                  <div>
                    <label for="company" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">Company Name</label>
                    <input type="text" id="company" name="company" autocomplete="organization"
                      class="w-full bg-bg-secondary border border-white/10 rounded-xl px-4 py-3 text-text-primary text-sm placeholder-text-subtle focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors"
                      placeholder="Acme Corp (optional)" />
                  </div>
                  <div>
                    <label for="email" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">Email <span class="text-blue-brand">*</span></label>
                    <input type="email" id="email" name="email" required autocomplete="email"
                      class="w-full bg-bg-secondary border border-white/10 rounded-xl px-4 py-3 text-text-primary text-sm placeholder-text-subtle focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors"
                      placeholder="john@company.com" />
                  </div>
                  <div>
                    <label for="phone" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">Phone <span class="text-blue-brand">*</span></label>
                    <input type="tel" id="phone" name="phone" required autocomplete="tel"
                      class="w-full bg-bg-secondary border border-white/10 rounded-xl px-4 py-3 text-text-primary text-sm placeholder-text-subtle focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors"
                      placeholder="(555) 555-5555" />
                  </div>
                </div>
              </div>

              <!-- Route -->
              <div>
                <h3 class="font-heading font-bold text-sm text-text-primary uppercase tracking-wider mb-4 flex items-center gap-2">
                  <span class="w-5 h-5 rounded-full bg-blue-brand/20 flex items-center justify-center text-[10px] text-blue-brand font-bold">2</span>
                  Route Details
                </h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label for="origin_city" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">Origin City <span class="text-blue-brand">*</span></label>
                    <input type="text" id="origin_city" name="origin_city" required
                      class="w-full bg-bg-secondary border border-white/10 rounded-xl px-4 py-3 text-text-primary text-sm placeholder-text-subtle focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors"
                      placeholder="Chicago" />
                  </div>
                  <div>
                    <label for="origin_state" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">Origin State <span class="text-blue-brand">*</span></label>
                    <input type="text" id="origin_state" name="origin_state" required maxlength="2"
                      class="w-full bg-bg-secondary border border-white/10 rounded-xl px-4 py-3 text-text-primary text-sm placeholder-text-subtle focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors uppercase"
                      placeholder="IL" />
                  </div>
                  <div>
                    <label for="dest_city" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">Destination City <span class="text-blue-brand">*</span></label>
                    <input type="text" id="dest_city" name="dest_city" required
                      class="w-full bg-bg-secondary border border-white/10 rounded-xl px-4 py-3 text-text-primary text-sm placeholder-text-subtle focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors"
                      placeholder="Dallas" />
                  </div>
                  <div>
                    <label for="dest_state" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">Destination State <span class="text-blue-brand">*</span></label>
                    <input type="text" id="dest_state" name="dest_state" required maxlength="2"
                      class="w-full bg-bg-secondary border border-white/10 rounded-xl px-4 py-3 text-text-primary text-sm placeholder-text-subtle focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors uppercase"
                      placeholder="TX" />
                  </div>
                </div>
              </div>

              <!-- Freight Details -->
              <div>
                <h3 class="font-heading font-bold text-sm text-text-primary uppercase tracking-wider mb-4 flex items-center gap-2">
                  <span class="w-5 h-5 rounded-full bg-blue-brand/20 flex items-center justify-center text-[10px] text-blue-brand font-bold">3</span>
                  Freight Details
                </h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label for="freight_type" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">Freight Type <span class="text-blue-brand">*</span></label>
                    <select id="freight_type" name="freight_type" required
                      class="w-full bg-bg-secondary border border-white/10 rounded-xl px-4 py-3 text-text-primary text-sm focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors appearance-none">
                      <option value="" disabled selected>Select type...</option>
                      <option value="Flatbed">Flatbed</option>
                      <option value="Dry Van">Dry Van</option>
                      <option value="Step Deck">Step Deck</option>
                      <option value="RGN / Lowboy">RGN / Lowboy</option>
                      <option value="Other">Other</option>
                    </select>
                  </div>
                  <div>
                    <label for="pickup_date" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">Pickup Date Needed <span class="text-blue-brand">*</span></label>
                    <div class="relative">
                      <input type="text" id="pickup_date" name="pickup_date" required readonly
                        class="w-full bg-bg-secondary border border-white/10 rounded-xl px-4 py-3 pr-10 text-text-primary text-sm placeholder-text-subtle focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors cursor-pointer"
                        placeholder="Select a date..." />
                      <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-text-subtle pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                      </svg>
                    </div>
                  </div>
                  <div>
                    <label for="commodity" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">Commodity / Cargo <span class="text-blue-brand">*</span></label>
                    <input type="text" id="commodity" name="commodity" required
                      class="w-full bg-bg-secondary border border-white/10 rounded-xl px-4 py-3 text-text-primary text-sm placeholder-text-subtle focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors"
                      placeholder="e.g. Steel coils, lumber, machinery" />
                  </div>
                  <div>
                    <label for="weight" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">Weight (lbs) <span class="text-blue-brand">*</span></label>
                    <input type="text" id="weight" name="weight" required
                      class="w-full bg-bg-secondary border border-white/10 rounded-xl px-4 py-3 text-text-primary text-sm placeholder-text-subtle focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors"
                      placeholder="e.g. 42,000" />
                  </div>
                  <div class="sm:col-span-2">
                    <label for="dimensions" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">Dimensions (L × W × H)</label>
                    <input type="text" id="dimensions" name="dimensions"
                      class="w-full bg-bg-secondary border border-white/10 rounded-xl px-4 py-3 text-text-primary text-sm placeholder-text-subtle focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors"
                      placeholder="e.g. 48ft × 8.5ft × 8ft (optional)" />
                  </div>
                </div>
              </div>

              <!-- Notes -->
              <div>
                <label for="notes" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">Special Requirements / Notes</label>
                <textarea id="notes" name="notes" rows="3"
                  class="w-full bg-bg-secondary border border-white/10 rounded-xl px-4 py-3 text-text-primary text-sm placeholder-text-subtle focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors resize-y min-h-[80px]"
                  placeholder="Tarps required, oversize load, hazmat, liftgate, inside delivery, etc."></textarea>
              </div>

              <!-- Submit -->
              <div>
                <button type="submit" id="submit-btn" class="btn-primary w-full justify-center py-4 text-base">
                  <span id="btn-text">Request My Quote</span>
                  <svg id="btn-arrow" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                  <svg id="btn-spinner" class="w-4 h-4 hidden animate-spin" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                  </svg>
                </button>

                <!-- Success message -->
                <div id="form-success" class="hidden mt-5 p-5 rounded-xl text-center" style="background: rgba(23,212,80,0.08); border: 1px solid rgba(23,212,80,0.25);">
                  <div class="text-2xl mb-2">✅</div>
                  <p class="font-heading font-bold text-white text-lg mb-1">Quote Request Received!</p>
                  <p class="text-text-muted text-sm">Harvey will reach out personally — usually within a few hours. Check your email or expect a call at the number you provided.</p>
                </div>

                <!-- Error message -->
                <div id="form-error" class="hidden mt-5 p-5 rounded-xl text-center" style="background: rgba(212,23,23,0.08); border: 1px solid rgba(212,23,23,0.25);">
                  <p class="font-semibold text-red-400 text-sm mb-1">Something went wrong.</p>
                  <p class="text-text-muted text-xs">Please try again or reach out directly at <a href="tel:+14793510393" class="text-blue-brand hover:underline">(479) 351-0393</a> or <a href="mailto:harveyr@bkelogistics.com" class="text-blue-brand hover:underline">harveyr@bkelogistics.com</a>.</p>
                </div>
              </div>

            </form>
          </div>

          <p class="text-text-subtle text-xs mt-4 px-1 leading-relaxed">
            Your information is used solely to prepare your freight quote. We do not sell or share your data. By submitting this form, you agree to be contacted by BKE Logistics LLC regarding your shipment.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom trust strip -->
  <section class="py-10 bg-bg-secondary border-t border-white/5">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="flex flex-wrap justify-center gap-8">
        {[
          { icon: '⚡', text: 'Same-Day Response' },
          { icon: '💰', text: 'No Hidden Fees' },
          { icon: '🔒', text: 'No Obligation Quote' },
          { icon: '📞', text: 'Direct Broker Access' },
        ].map(item => (
          <div class="flex items-center gap-2 text-text-muted">
            <span>{item.icon}</span>
            <span class="text-sm font-medium">{item.text}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<!-- Flatpickr date picker -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
<style is:inline>
  /* Override flatpickr to match dark site theme */
  .flatpickr-calendar {
    background: #0f1623;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.6);
    font-family: inherit;
  }
  .flatpickr-calendar.arrowTop:before,
  .flatpickr-calendar.arrowTop:after { border-bottom-color: #0f1623; }
  .flatpickr-months { background: transparent; padding: 8px 0; }
  .flatpickr-month { color: #fff; fill: #fff; }
  .flatpickr-current-month { color: #fff; font-size: 1rem; font-weight: 700; }
  .flatpickr-current-month .flatpickr-monthDropdown-months {
    background: #0f1623; color: #fff;
  }
  .flatpickr-current-month input.cur-year { color: #fff; }
  .flatpickr-prev-month, .flatpickr-next-month { color: #94a3b8; fill: #94a3b8; }
  .flatpickr-prev-month:hover, .flatpickr-next-month:hover { color: #1769d4; fill: #1769d4; }
  .flatpickr-weekdays { background: transparent; }
  span.flatpickr-weekday { color: #64748b; font-weight: 600; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .flatpickr-day {
    color: #94a3b8;
    border-radius: 8px;
    border: 1px solid transparent;
  }
  .flatpickr-day:hover, .flatpickr-day:focus {
    background: rgba(23,105,212,0.15);
    border-color: rgba(23,105,212,0.3);
    color: #fff;
  }
  .flatpickr-day.selected, .flatpickr-day.selected:hover {
    background: #1769d4;
    border-color: #1769d4;
    color: #fff;
    font-weight: 700;
  }
  .flatpickr-day.today { border-color: rgba(23,105,212,0.5); color: #fff; }
  .flatpickr-day.today:hover { background: rgba(23,105,212,0.2); }
  .flatpickr-day.flatpickr-disabled, .flatpickr-day.prevMonthDay, .flatpickr-day.nextMonthDay {
    color: #334155; opacity: 0.4;
  }
  .numInputWrapper span.arrowUp:after { border-bottom-color: #94a3b8; }
  .numInputWrapper span.arrowDown:after { border-top-color: #94a3b8; }
  .numInputWrapper:hover { background: rgba(255,255,255,0.04); }
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script define:vars={{ OPENCLAW_WEBHOOK_URL }}>
  // Initialize flatpickr date picker
  const today = new Date();
  today.setHours(0, 0, 0, 0);
  flatpickr('#pickup_date', {
    minDate: today,
    dateFormat: 'M j, Y',
    disableMobile: false,
    allowInput: false,
    theme: 'dark',
  });

  const form = document.getElementById('quote-form');
  const submitBtn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');
  const btnArrow = document.getElementById('btn-arrow');
  const btnSpinner = document.getElementById('btn-spinner');
  const formSuccess = document.getElementById('form-success');
  const formError = document.getElementById('form-error');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const name = form.full_name.value.trim();
    const company = form.company.value.trim();
    const email = form.email.value.trim();
    const phone = form.phone.value.trim();
    const origin = `${form.origin_city.value.trim()}, ${form.origin_state.value.trim().toUpperCase()}`;
    const destination = `${form.dest_city.value.trim()}, ${form.dest_state.value.trim().toUpperCase()}`;
    const freightType = form.freight_type.value;
    const commodity = form.commodity.value.trim();
    const weight = form.weight.value.trim();
    const dimensions = form.dimensions.value.trim();
    const pickupDate = form.pickup_date.value;
    const notes = form.notes.value.trim();

    const messageText = `[Quote Request] Name: ${name}${company ? ` | Company: ${company}` : ''} | Email: ${email} | Phone: ${phone} | Origin: ${origin} | Destination: ${destination} | Type: ${freightType} | Commodity: ${commodity} | Weight: ${weight} lbs | Pickup: ${pickupDate}${dimensions ? ` | Dimensions: ${dimensions}` : ''}${notes ? ` | Notes: ${notes}` : ''}`;

    const payload = {
      message: messageText,
    };

    // Loading state
    submitBtn.disabled = true;
    btnText.textContent = 'Sending...';
    btnArrow.classList.add('hidden');
    btnSpinner.classList.remove('hidden');
    formSuccess.classList.add('hidden');
    formError.classList.add('hidden');

    try {
      const response = await fetch(OPENCLAW_WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!response.ok) throw new Error(`HTTP ${response.status}`);

      form.reset();
      formSuccess.classList.remove('hidden');
    } catch (err) {
      formError.classList.remove('hidden');
      console.error('Quote form error:', err);
    } finally {
      submitBtn.disabled = false;
      btnText.textContent = 'Request My Quote';
      btnArrow.classList.remove('hidden');
      btnSpinner.classList.add('hidden');
    }
  });
</script>
