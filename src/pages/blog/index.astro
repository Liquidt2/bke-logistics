---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPosts } from '../../lib/sanity';

let posts: any[] = [];
let error = false;

try {
  posts = await getAllPosts();
} catch (e) {
  error = true;
}

function formatDate(dateStr: string) {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="Blog & Market Updates"
  description="Freight market insights, logistics tips, and industry updates from BKE Logistics LLC. Stay informed with our latest articles."
>
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">

      <!-- Header -->
      <div class="mb-14">
        <span class="section-label block mb-3">Market Insights</span>
        <h1 class="font-heading font-black text-5xl lg:text-6xl text-text-primary leading-tight mb-4">
          Blog & Updates
        </h1>
        <p class="text-text-muted text-lg max-w-2xl leading-relaxed">
          Freight market trends, logistics insights, and industry updates — straight from the BKE Logistics team.
        </p>
      </div>

      {error && (
        <div class="rounded-2xl p-8 text-center" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);">
          <p class="text-text-muted">Blog posts are loading. Check back soon.</p>
        </div>
      )}

      {!error && posts.length === 0 && (
        <div class="rounded-2xl p-12 text-center" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);">
          <div class="text-5xl mb-4">📝</div>
          <h2 class="font-heading font-bold text-2xl text-text-primary mb-2">Posts Coming Soon</h2>
          <p class="text-text-muted text-sm max-w-md mx-auto">
            We're getting our blog set up. Check back soon for freight market updates and logistics insights.
          </p>
        </div>
      )}

      {!error && posts.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map(post => (
            <a
              href={`/blog/${post.slug?.current}`}
              class="group rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-2 flex flex-col"
              style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 4px 24px rgba(0,0,0,0.3);"
            >
              <!-- Image -->
              {post.mainImageUrl ? (
                <div class="h-48 overflow-hidden">
                  <img
                    src={post.mainImageUrl}
                    alt={post.title}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
              ) : (
                <div class="h-48 flex items-center justify-center" style="background: rgba(23,105,212,0.08);">
                  <svg class="w-12 h-12 text-blue-brand/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
                  </svg>
                </div>
              )}

              <!-- Content -->
              <div class="p-6 flex flex-col flex-1">
                {post.categories?.length > 0 && (
                  <div class="flex flex-wrap gap-2 mb-3">
                    {post.categories.map((cat: string) => (
                      <span class="text-[11px] font-semibold uppercase tracking-wider text-blue-brand px-2.5 py-1 rounded-lg" style="background: rgba(23,105,212,0.12);">
                        {cat}
                      </span>
                    ))}
                  </div>
                )}

                <h2 class="font-heading font-bold text-xl text-text-primary leading-snug mb-3 group-hover:text-blue-light transition-colors flex-1">
                  {post.title}
                </h2>

                {post.excerpt && (
                  <p class="text-text-muted text-sm leading-relaxed mb-4 line-clamp-2">
                    {post.excerpt}
                  </p>
                )}

                <div class="flex items-center justify-between pt-4 border-t border-white/[0.06] mt-auto">
                  <span class="text-text-subtle text-xs">
                    {formatDate(post.publishedAt)}
                  </span>
                  <span class="text-blue-brand text-sm font-medium group-hover:gap-2 transition-all flex items-center gap-1">
                    Read
                    <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}

    </div>
  </section>
</BaseLayout>
