---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import QuoteSection from '../components/QuoteSection.astro';

const values = [
  {
    icon: '🎯',
    title: 'Reliability',
    description: 'A commitment is a commitment. When we accept a load, we deliver it — on time, with the equipment specified, and with the care your cargo requires. Our on-time performance record reflects that this isn\'t just a talking point.',
  },
  {
    icon: '🔍',
    title: 'Transparency',
    description: 'No surprises. Clear pricing from the start, real-time status updates in transit, and honest communication when circumstances change. We believe shippers deserve to know exactly what\'s happening with their freight.',
  },
  {
    icon: '🛡️',
    title: 'Safety',
    description: 'Safety is non-negotiable at BKE Logistics. Our carriers maintain DOT compliance and clean safety records. We do not cut corners on Hours of Service, equipment inspections, or load securement — ever.',
  },
  {
    icon: '⭐',
    title: 'Excellence',
    description: 'Good enough is never our standard. From how we answer the phone to how our drivers present themselves at the shipper\'s dock, we hold every aspect of our service to a high standard because that\'s what our clients deserve.',
  },
];

const milestones = [
  { year: '2014', event: 'BKE Logistics LLC founded with a focus on flatbed freight in the Midwest' },
  { year: '2016', event: 'Expanded dry van capabilities and Southeast corridor coverage' },
  { year: '2018', event: 'Launched 24/7 dispatch operations for around-the-clock client support' },
  { year: '2020', event: 'Grew carrier network to cover all 48 contiguous states' },
  { year: '2022', event: 'Surpassed 500 consistent clients and 10,000 loads delivered' },
  { year: '2024', event: 'Continued expansion into energy sector and oversized freight corridors' },
];
---

<BaseLayout
  title="About BKE Logistics"
  description="Learn about BKE Logistics LLC — our story, mission, core values, and commitment to reliable, transparent freight services across the United States."
>
  <PageHero
    title="About BKE Logistics"
    subtitle="We're a team of freight professionals who believe that logistics done right is more than moving boxes from A to B — it's about earning trust one shipment at a time."
    breadcrumb={[{ label: 'About' }]}
    eyebrow="Our Story"
  />

  <!-- Story / Mission -->
  <section class="py-16 lg:py-24 bg-bg">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 lg:gap-20 items-start">
        <div>
          <span class="section-label block mb-3">Who We Are</span>
          <h2 class="font-heading font-bold text-3xl lg:text-4xl text-text-primary mb-6">
            Built by Freight People, for Freight People
          </h2>
          <p class="text-text-muted leading-relaxed mb-5">
            BKE Logistics LLC was founded with a straightforward premise: freight brokerage and carrier services should be simple, reliable, and honest. Too many shippers had been burned by brokers who overpromised, underdelivered, and disappeared when things went sideways. We set out to be different.
          </p>
          <p class="text-text-muted leading-relaxed mb-5">
            From our first flatbed load in the Midwest, we focused on building genuine carrier relationships — not just filling load boards. That meant paying on time, communicating clearly, and treating every driver and shipper like a long-term partner rather than a transaction.
          </p>
          <p class="text-text-muted leading-relaxed">
            Today, BKE Logistics serves clients across manufacturing, construction, agriculture, retail, and energy, with a carrier network spanning all 48 contiguous states. Our dispatch team operates around the clock, because freight doesn't stop at 5 PM and neither do we.
          </p>
        </div>

        <div>
          <span class="section-label block mb-3">Our Mission</span>
          <div class="bg-navy border border-blue-brand/20 rounded-sm p-8 mb-6">
            <div class="font-heading font-black text-5xl text-blue-brand/20 leading-none mb-3">"</div>
            <p class="font-heading font-bold text-2xl text-text-primary leading-snug">
              To be the freight partner that shippers actually rely on — with the reliability, transparency, and communication that the industry has historically failed to deliver consistently.
            </p>
          </div>

          <!-- Timeline -->
          <div class="space-y-4">
            {milestones.map(m => (
              <div class="flex gap-4">
                <div class="w-12 shrink-0">
                  <div class="font-heading font-bold text-blue-brand text-sm">{m.year}</div>
                </div>
                <div class="flex-1 pb-4 border-b border-white/5 last:border-0">
                  <p class="text-text-muted text-sm leading-relaxed">{m.event}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section class="py-16 lg:py-20 bg-bg-secondary border-y border-white/5" aria-labelledby="values-heading">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="text-center mb-12">
        <span class="section-label block mb-3">What Drives Us</span>
        <h2 id="values-heading" class="font-heading font-bold text-3xl lg:text-4xl text-text-primary">
          Our Core Values
        </h2>
        <p class="text-text-muted mt-3 max-w-xl mx-auto text-sm">
          These aren't slogans on a wall. They're the operating principles that guide every decision we make, every day.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {values.map(value => (
          <div class="bg-bg-card border border-white/5 rounded-sm p-7 hover:border-blue-brand/25 transition-all duration-300 group hover:shadow-blue-glow text-center">
            <div class="text-4xl mb-4">{value.icon}</div>
            <h3 class="font-heading font-bold text-xl text-text-primary mb-3 group-hover:text-blue-brand transition-colors">
              {value.title}
            </h3>
            <p class="text-text-muted text-sm leading-relaxed">
              {value.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team placeholder -->
  <section class="py-16 lg:py-20 bg-bg">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="flex flex-col lg:flex-row gap-12 items-start">
        <div class="lg:w-1/2">
          <span class="section-label block mb-3">Leadership</span>
          <h2 class="font-heading font-bold text-3xl lg:text-4xl text-text-primary mb-5">
            The Team Behind BKE
          </h2>
          <p class="text-text-muted leading-relaxed mb-4">
            BKE Logistics is led by industry veterans who have worked in freight brokerage, carrier operations, and shipper logistics. This cross-perspective experience means we understand the challenges on every side of the freight equation.
          </p>
          <p class="text-text-muted leading-relaxed text-sm">
            Our dispatch and operations team members have an average of 7+ years in the trucking industry. They know the lanes, the carriers, and the challenges — and they use that knowledge every day to solve problems before they become your problem.
          </p>
        </div>

        <div class="lg:w-1/2 grid grid-cols-2 gap-4">
          {['Operations & Dispatch', 'Carrier Relations', 'Account Management', 'Compliance & Safety'].map(role => (
            <div class="bg-bg-card border border-white/8 rounded-sm p-5 text-center hover:border-blue-brand/20 transition-colors">
              <div class="w-12 h-12 rounded-full bg-navy/60 border border-white/10 mx-auto mb-3 flex items-center justify-center">
                <svg class="w-5 h-5 text-text-subtle" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </div>
              <div class="text-text-muted text-xs font-medium">{role}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <QuoteSection
    headline="Ready to Partner With BKE?"
    subtext="Whether you have a load to move today or you're evaluating long-term freight partnerships, we're ready to show you what reliable logistics looks like."
  />
</BaseLayout>
