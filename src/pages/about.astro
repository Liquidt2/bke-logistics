---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import QuoteSection from '../components/QuoteSection.astro';

const values = [
  {
    icon: '🎯',
    title: 'Reliability',
    description: 'When Harvey commits to covering a load, it gets covered. No ghosting, no excuses. Shippers deserve a broker who follows through — and that starts with answering the phone.',
  },
  {
    icon: '🔍',
    title: 'Transparency',
    description: 'You\'ll know the rate, the carrier, and the status of your freight. No surprises at delivery. Honest communication is the foundation of every relationship BKE builds.',
  },
  {
    icon: '🛡️',
    title: 'Carrier Vetting',
    description: 'BKE only works with vetted, insured carriers who maintain clean safety records. Harvey\'s background as a trucking company owner means he knows exactly what to look for.',
  },
  {
    icon: '⭐',
    title: 'Personal Service',
    description: 'You\'re not calling a call center. When you work with BKE Logistics, you work directly with Harvey — someone with real skin in the game and real freight experience behind him.',
  },
];

const credentials = [
  { label: 'MC Number', value: '1588065' },
  { label: 'DOT Number', value: '4141583-B' },
  { label: 'Bond', value: 'BMC-84 Surety Bond' },
  { label: 'Authority', value: 'FMCSA Licensed Broker' },
  { label: 'Founded', value: 'October 2024' },
  { label: 'Based In', value: 'Hector, Arkansas' },
];
---

<BaseLayout
  title="About BKE Logistics"
  description="Learn about BKE Logistics LLC — our story, mission, core values, and commitment to reliable, transparent freight services across the United States."
>
  <PageHero
    title="About BKE Logistics"
    subtitle="Founded by a trucking industry veteran who's been the driver, the owner, and now the broker — BKE Logistics brings firsthand freight expertise to every load."
    breadcrumb={[{ label: 'About' }]}
    eyebrow="Our Story"
  />

  <!-- Story / Mission -->
  <section class="py-16 lg:py-24 bg-bg">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 lg:gap-20 items-start">
        <div>
          <span class="section-label block mb-3">Who We Are</span>
          <h2 class="font-heading font-bold text-3xl lg:text-4xl text-text-primary mb-6">
            Built by Someone Who's Been Behind the Wheel
          </h2>
          <p class="text-text-muted leading-relaxed mb-5">
            BKE Logistics LLC was founded in October 2024 by Harvey Roberts — a freight industry veteran who's done it all. Harvey has owned and operated his own trucking company and driven the loads himself. That firsthand experience on both sides of the dock means he understands what shippers need and what carriers face, and he brings that knowledge to every freight move he brokers.
          </p>
          <p class="text-text-muted leading-relaxed mb-5">
            The name BKE means everything to Harvey — it stands for his three kids, Brayden, Kennedy, and Eli. That's not just a fun fact; it's a reflection of the values that drive the business. Every load is handled with the care you'd want if your name — and your family's name — was on it.
          </p>
          <p class="text-text-muted leading-relaxed">
            Based in Hector, Arkansas, BKE Logistics is an FMCSA-licensed freight broker specializing in flatbed and dry van freight across all 48 contiguous states. From steel coils and lumber to construction equipment and consumer goods, Harvey matches shippers with the right carriers and keeps communication clear from pickup to delivery.
          </p>
        </div>

        <div>
          <span class="section-label block mb-3">Our Mission</span>
          <div class="bg-navy border border-blue-brand/20 rounded-sm p-8 mb-6">
            <div class="font-heading font-black text-5xl text-blue-brand/20 leading-none mb-3">"</div>
            <p class="font-heading font-bold text-2xl text-text-primary leading-snug">
              To be the freight broker that shippers actually trust — because I've been in their shoes, and I know what it means when a load doesn't show up.
            </p>
          </div>

          <!-- Credentials -->
          <div class="grid grid-cols-2 gap-3 mt-2">
            {credentials.map(c => (
              <div class="p-4 rounded-xl" style="background: rgba(23,105,212,0.06); border: 1px solid rgba(23,105,212,0.18);">
                <div class="text-text-subtle text-xs uppercase tracking-wider mb-1">{c.label}</div>
                <div class="font-heading font-bold text-text-primary text-sm">{c.value}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section class="py-16 lg:py-20 bg-bg-secondary border-y border-white/5" aria-labelledby="values-heading">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="text-center mb-12">
        <span class="section-label block mb-3">What Drives Us</span>
        <h2 id="values-heading" class="font-heading font-bold text-3xl lg:text-4xl text-text-primary">
          Our Core Values
        </h2>
        <p class="text-text-muted mt-3 max-w-xl mx-auto text-sm">
          These aren't slogans on a wall. They're the operating principles that guide every decision we make, every day.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {values.map(value => (
          <div class="bg-bg-card border border-white/5 rounded-sm p-7 hover:border-blue-brand/25 transition-all duration-300 group hover:shadow-blue-glow text-center">
            <div class="text-4xl mb-4">{value.icon}</div>
            <h3 class="font-heading font-bold text-xl text-text-primary mb-3 group-hover:text-blue-brand transition-colors">
              {value.title}
            </h3>
            <p class="text-text-muted text-sm leading-relaxed">
              {value.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Owner -->
  <section class="py-16 lg:py-20 bg-bg">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="flex flex-col lg:flex-row gap-12 items-center">
        <div class="lg:w-1/2">
          <span class="section-label block mb-3">Owner & Broker</span>
          <h2 class="font-heading font-bold text-3xl lg:text-4xl text-text-primary mb-5">
            Harvey Roberts
          </h2>
          <p class="text-text-muted leading-relaxed mb-4">
            Harvey has worked in the trucking industry from the ground up — as a commercial driver and as a trucking company owner. That experience gives him a perspective most freight brokers simply don't have. He knows what it takes to load a flatbed correctly, what drivers deal with on the road, and what shippers need to keep their operations running.
          </p>
          <p class="text-text-muted leading-relaxed mb-6">
            Now as an FMCSA-licensed freight broker, Harvey puts that experience to work for his clients — finding the right carrier for every load, negotiating fair rates, and staying in communication from start to finish. No middleman runaround. Just straight-talking freight service from someone who's done the work.
          </p>
          <div class="flex flex-wrap gap-3">
            {['Former Trucking Company Owner', 'Commercial Driver', 'FMCSA Licensed Broker', 'Surety Bonded'].map(tag => (
              <span class="text-xs font-medium text-text-muted px-3 py-1.5 rounded-lg" style="background: rgba(23,105,212,0.08); border: 1px solid rgba(23,105,212,0.2);">{tag}</span>
            ))}
          </div>
        </div>

        <div class="lg:w-1/2 grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            { icon: '📞', label: 'Direct Line', value: '(479) 351-0393', note: 'Call or text Harvey directly' },
            { icon: '✉️', label: 'Email', value: 'harveyr@bkelogistics.com', note: 'Responds within hours' },
            { icon: '📍', label: 'Based In', value: 'Hector, Arkansas', note: 'Serving all 48 states' },
            { icon: '🏷️', label: 'MC Number', value: '#1588065', note: 'FMCSA Licensed & Bonded' },
          ].map(item => (
            <div class="rounded-2xl p-5 hover:border-blue-brand/20 transition-colors" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);">
              <div class="text-2xl mb-2">{item.icon}</div>
              <div class="text-text-subtle text-xs uppercase tracking-wider mb-1">{item.label}</div>
              <div class="font-heading font-bold text-text-primary text-sm">{item.value}</div>
              <div class="text-text-subtle text-xs mt-1">{item.note}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <QuoteSection
    headline="Ready to Partner With BKE?"
    subtext="Whether you have a load to move today or you're evaluating long-term freight partnerships, we're ready to show you what reliable logistics looks like."
  />
</BaseLayout>
