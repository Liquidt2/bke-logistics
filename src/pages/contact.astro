---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import QuoteSection from '../components/QuoteSection.astro';
---

<BaseLayout
  title="Contact Us"
  description="Contact BKE Logistics LLC — reach our dispatch team by phone or email. We're available 24/7 for freight inquiries, quotes, and shipment support."
>
  <PageHero
    title="Contact Us"
    subtitle="Reach our team any time. Whether you have a load to move, a question about our services, or need to check on a shipment, we're here."
    breadcrumb={[{ label: 'Contact' }]}
    eyebrow="Get In Touch"
  />

  <section class="py-16 lg:py-24 bg-bg">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">

        <!-- Contact Information -->
        <div>
          <h2 class="font-heading font-bold text-2xl text-text-primary mb-8">Contact Information</h2>

          <div class="space-y-6 mb-10">
            <!-- Phone -->
            <div class="flex gap-5 items-start p-5 bg-bg-card border border-white/8 rounded-sm hover:border-blue-brand/20 transition-colors group">
              <div class="w-10 h-10 bg-blue-brand/10 border border-blue-brand/20 rounded-sm flex items-center justify-center shrink-0 group-hover:bg-blue-brand/20 transition-colors">
                <svg class="w-5 h-5 text-blue-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <div class="text-text-subtle text-xs uppercase tracking-wider font-semibold mb-1">Dispatch Line</div>
                <a href="tel:+14793510393" class="font-heading font-bold text-xl text-text-primary hover:text-blue-brand transition-colors">(479) 351-0393</a>
                <div class="text-text-subtle text-xs mt-1">Call or text — we respond fast</div>
              </div>
            </div>

            <!-- Email -->
            <div class="flex gap-5 items-start p-5 bg-bg-card border border-white/8 rounded-sm hover:border-blue-brand/20 transition-colors group">
              <div class="w-10 h-10 bg-blue-brand/10 border border-blue-brand/20 rounded-sm flex items-center justify-center shrink-0 group-hover:bg-blue-brand/20 transition-colors">
                <svg class="w-5 h-5 text-blue-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <div class="text-text-subtle text-xs uppercase tracking-wider font-semibold mb-1">Email</div>
                <a href="mailto:harveyr@bkelogistics.com" class="font-heading font-bold text-xl text-text-primary hover:text-blue-brand transition-colors">
                  harveyr@bkelogistics.com
                </a>
                <div class="text-text-subtle text-xs mt-1">Typical response: within a few hours</div>
              </div>
            </div>

            <!-- Location -->
            <div class="flex gap-5 items-start p-5 bg-bg-card border border-white/8 rounded-sm hover:border-blue-brand/20 transition-colors group">
              <div class="w-10 h-10 bg-blue-brand/10 border border-blue-brand/20 rounded-sm flex items-center justify-center shrink-0 group-hover:bg-blue-brand/20 transition-colors">
                <svg class="w-5 h-5 text-blue-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <div class="text-text-subtle text-xs uppercase tracking-wider font-semibold mb-1">Location</div>
                <div class="font-heading font-bold text-xl text-text-primary">Hector, Arkansas</div>
                <div class="text-text-subtle text-xs mt-1">19840 SR 124 · Serving all 48 states</div>
              </div>
            </div>
          </div>

          <!-- Business Hours -->
          <div class="bg-navy/30 border border-navy-light/20 rounded-sm p-6">
            <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
              <span class="text-blue-brand">⏰</span> Business Hours
            </h3>
            <div class="space-y-2.5">
              {[
                { days: 'Monday – Friday', hours: '8:00 AM – 6:00 PM CT', note: 'Primary availability' },
                { days: 'Saturday', hours: '9:00 AM – 2:00 PM CT', note: 'Limited availability' },
                { days: 'Sunday', hours: 'By phone/text', note: 'For urgent freight needs' },
              ].map(row => (
                <div class="flex items-start justify-between gap-4 py-2 border-b border-white/5 last:border-0">
                  <div>
                    <div class="text-text-primary text-sm font-medium">{row.days}</div>
                    <div class="text-text-subtle text-xs">{row.note}</div>
                  </div>
                  <div class="text-text-muted text-sm text-right">{row.hours}</div>
                </div>
              ))}
            </div>
            <div class="mt-4 p-3 bg-blue-brand/10 border border-blue-brand/20 rounded-sm">
              <p class="text-blue-brand text-xs font-medium">
                📞 When you call BKE, you reach Harvey directly — not a call center.
              </p>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <h2 class="font-heading font-bold text-2xl text-text-primary mb-8">Send a Message</h2>

          <div class="p-1 mb-4 bg-navy/20 border border-blue-brand/10 rounded-sm">
            <p class="text-text-subtle text-xs p-3 leading-relaxed">
              <strong class="text-text-muted">Note:</strong> This is an HTML-only form. To enable form submissions, connect to
              <a href="https://www.zoho.com/forms/" target="_blank" rel="noopener noreferrer" class="text-blue-brand hover:underline">Zoho Forms</a> or
              <a href="https://formspree.io" target="_blank" rel="noopener noreferrer" class="text-blue-brand hover:underline">Formspree</a>.
              Update the <code>action</code> attribute on the &lt;form&gt; tag with your endpoint.
            </p>
          </div>

          <form
            id="contact-form"
            action="#"
            method="POST"
            class="space-y-5"
            aria-label="Contact form"
          >
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="first-name" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">
                  First Name <span class="text-blue-brand">*</span>
                </label>
                <input
                  type="text"
                  id="first-name"
                  name="first_name"
                  required
                  autocomplete="given-name"
                  class="w-full bg-bg-secondary border border-white/10 rounded-sm px-4 py-3 text-text-primary text-sm placeholder-text-subtle focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors"
                  placeholder="John"
                />
              </div>
              <div>
                <label for="last-name" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">
                  Last Name <span class="text-blue-brand">*</span>
                </label>
                <input
                  type="text"
                  id="last-name"
                  name="last_name"
                  required
                  autocomplete="family-name"
                  class="w-full bg-bg-secondary border border-white/10 rounded-sm px-4 py-3 text-text-primary text-sm placeholder-text-subtle focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors"
                  placeholder="Smith"
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">
                Email Address <span class="text-blue-brand">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="w-full bg-bg-secondary border border-white/10 rounded-sm px-4 py-3 text-text-primary text-sm placeholder-text-subtle focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors"
                placeholder="john@company.com"
              />
            </div>

            <div>
              <label for="phone" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">
                Phone Number
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                autocomplete="tel"
                class="w-full bg-bg-secondary border border-white/10 rounded-sm px-4 py-3 text-text-primary text-sm placeholder-text-subtle focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors"
                placeholder="(XXX) XXX-XXXX"
              />
            </div>

            <div>
              <label for="subject" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">
                Subject <span class="text-blue-brand">*</span>
              </label>
              <select
                id="subject"
                name="subject"
                required
                class="w-full bg-bg-secondary border border-white/10 rounded-sm px-4 py-3 text-text-primary text-sm focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors appearance-none"
              >
                <option value="" disabled selected class="text-text-subtle">Select a topic...</option>
                <option value="quote">Request a Freight Quote</option>
                <option value="shipment">Active Shipment Inquiry</option>
                <option value="services">General Services Question</option>
                <option value="carrier">Carrier Partnership</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-text-muted text-xs font-semibold uppercase tracking-wider mb-2">
                Message <span class="text-blue-brand">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                class="w-full bg-bg-secondary border border-white/10 rounded-sm px-4 py-3 text-text-primary text-sm placeholder-text-subtle focus:outline-none focus:border-blue-brand focus:ring-1 focus:ring-blue-brand/30 transition-colors resize-y min-h-[120px]"
                placeholder="Tell us about your freight needs, shipment details, or questions..."
              ></textarea>
            </div>

            <button
              type="submit"
              id="contact-submit-btn"
              class="btn-primary w-full justify-center py-4"
            >
              <span id="contact-btn-text">Send Message</span>
              <svg id="contact-btn-arrow" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
              <svg id="contact-btn-spinner" class="w-4 h-4 hidden animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
            </button>

            <div id="contact-success" class="hidden mt-5 p-5 rounded-xl text-center" style="background: rgba(23,212,80,0.08); border: 1px solid rgba(23,212,80,0.25);">
              <div class="text-2xl mb-2">✅</div>
              <p class="font-heading font-bold text-white text-lg mb-1">Message Sent!</p>
              <p class="text-text-muted text-sm">Harvey will be in touch soon — expect a response within a few hours.</p>
            </div>

            <div id="contact-error" class="hidden mt-5 p-5 rounded-xl text-center" style="background: rgba(212,23,23,0.08); border: 1px solid rgba(212,23,23,0.25);">
              <p class="font-semibold text-red-400 text-sm mb-1">Something went wrong.</p>
              <p class="text-text-muted text-xs">Please try again or reach Harvey directly at <a href="tel:+14793510393" class="text-blue-brand hover:underline">(479) 351-0393</a>.</p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <QuoteSection
    headline="Need a Rate — Fast?"
    subtext="Skip the form and go straight to a quote. Harvey responds personally within hours — no obligation, no pressure."
    ctaLabel="Request a Quote"
  />
</BaseLayout>

<script>
  const WEBHOOK_URL = '/api/webhook';
  const WEBHOOK_TO = '7237377009';

  const form = document.getElementById('contact-form');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitBtn = document.getElementById('contact-submit-btn');
      const btnText = document.getElementById('contact-btn-text');
      const btnArrow = document.getElementById('contact-btn-arrow');
      const btnSpinner = document.getElementById('contact-btn-spinner');
      const successEl = document.getElementById('contact-success');
      const errorEl = document.getElementById('contact-error');

      const firstName = (form.querySelector('#first-name') as HTMLInputElement).value.trim();
      const lastName = (form.querySelector('#last-name') as HTMLInputElement).value.trim();
      const email = (form.querySelector('#email') as HTMLInputElement).value.trim();
      const phone = (form.querySelector('#phone') as HTMLInputElement).value.trim();
      const subject = (form.querySelector('#subject') as HTMLSelectElement).value;
      const message = (form.querySelector('#message') as HTMLTextAreaElement).value.trim();

      const messageText = `[Contact Form] Name: ${firstName} ${lastName} | Email: ${email}${phone ? ` | Phone: ${phone}` : ''} | Subject: ${subject} | Message: ${message}`;

      const payload = {
        message: messageText,
        name: 'Website Forms',
        wakeMode: 'now',
        deliver: true,
        channel: 'telegram',
        to: WEBHOOK_TO,
      };

      submitBtn.disabled = true;
      btnText.textContent = 'Sending...';
      btnArrow.classList.add('hidden');
      btnSpinner.classList.remove('hidden');
      successEl.classList.add('hidden');
      errorEl.classList.add('hidden');

      try {
        const response = await fetch(WEBHOOK_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (!response.ok) throw new Error(`HTTP ${response.status}`);

        form.reset();
        successEl.classList.remove('hidden');
      } catch (err) {
        errorEl.classList.remove('hidden');
        console.error('Contact form error:', err);
      } finally {
        submitBtn.disabled = false;
        btnText.textContent = 'Send Message';
        btnArrow.classList.remove('hidden');
        btnSpinner.classList.add('hidden');
      }
    });
  }
</script>
