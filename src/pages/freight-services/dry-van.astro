---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import QuoteSection from '../../components/QuoteSection.astro';

const loadTypes = [
  { icon: '🛒', title: 'Consumer & Retail Goods', desc: 'Packaged products, apparel, household goods, and general merchandise destined for distribution centers and retail stores.' },
  { icon: '🖨️', title: 'Paper & Printing Products', desc: 'Rolls, sheets, printed materials, and packaging components requiring clean, dry, enclosed transport.' },
  { icon: '🏭', title: 'Manufactured Parts', desc: 'Automotive components, electronics assemblies, and industrial parts that need protection from weather and road debris.' },
  { icon: '🥫', title: 'Non-Refrigerated Food', desc: 'Canned goods, dry goods, bagged products, and non-perishable food items in food-grade clean trailers.' },
  { icon: '📱', title: 'Electronics & Tech', desc: 'Packaged electronics, appliances, and technology equipment that require secure, weather-tight transport conditions.' },
  { icon: '🧴', title: 'Health & Personal Care', desc: 'Consumer health products, pharmaceuticals (ambient), and personal care goods requiring sanitary transport.' },
];

const whyBKE = [
  { title: 'Consistent On-Time Delivery', desc: 'Our routing and dispatch process is built around your delivery windows. We track every load actively and communicate before issues arise.' },
  { title: 'Vetted Carrier Network', desc: 'Every carrier in our dry van network is thoroughly vetted — safety scores, insurance verification, equipment inspections, and driver records.' },
  { title: 'Competitive, Transparent Pricing', desc: 'No surprise fees, no hidden accessorials. Our quotes are detailed and honest so you can plan your logistics budget confidently.' },
  { title: 'Flexible Capacity', desc: 'Need a truck next week? Next month? We offer spot market quotes and contract rates for shippers with predictable volume needs.' },
];
---

<BaseLayout
  title="Dry Van Freight"
  description="BKE Logistics LLC dry van freight services — enclosed trailer transport for consumer goods, retail products, manufactured parts, and general freight. 48 states."
>
  <PageHero
    title="Dry Van Freight"
    subtitle="Enclosed trailer transport built for cargo that demands protection. From consumer goods to manufactured parts, we deliver on time and in perfect condition."
    breadcrumb={[
      { label: 'Freight Services', href: '/freight-services' },
      { label: 'Dry Van' },
    ]}
    eyebrow="Enclosed Freight Transport"
  />

  <!-- What is Dry Van -->
  <section class="py-16 lg:py-20 bg-bg">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <span class="section-label block mb-3">About Dry Van</span>
          <h2 class="font-heading font-bold text-3xl lg:text-4xl text-text-primary mb-5">
            What Is Dry Van Freight?
          </h2>
          <p class="text-text-muted leading-relaxed mb-4">
            Dry van is the most common mode of truck freight in North America. These fully enclosed, non-refrigerated trailers protect cargo from rain, wind, road debris, and tampering while in transit. The "dry" designation distinguishes them from refrigerated (reefer) trailers — they maintain ambient temperature without active temperature control.
          </p>
          <p class="text-text-muted leading-relaxed mb-6">
            Standard dry van trailers measure 53 feet long, 8'6" wide, and 9'2" tall inside, offering approximately 2,680 cubic feet of cargo space and a payload capacity of up to 44,000–46,000 lbs. Freight is loaded on pallets or in boxes and secured with load bars and strapping.
          </p>
        </div>

        <div class="grid grid-cols-2 gap-3">
          {[
            { label: 'Trailer Length', value: '53 feet' },
            { label: 'Interior Height', value: '9\'2"' },
            { label: 'Max Payload', value: '~45,000 lbs' },
            { label: 'Pallet Capacity', value: '26 pallets' },
          ].map(spec => (
            <div class="bg-bg-card border border-white/8 rounded-sm p-5 text-center">
              <div class="font-heading font-black text-3xl text-blue-brand mb-1">{spec.value}</div>
              <div class="text-text-muted text-xs font-medium uppercase tracking-wide">{spec.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Load Types -->
  <section class="py-16 lg:py-20 bg-bg-secondary border-y border-white/5">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="mb-12">
        <span class="section-label block mb-3">Cargo We Handle</span>
        <h2 class="font-heading font-bold text-3xl lg:text-4xl text-text-primary">
          What We Move in Dry Van
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {loadTypes.map(load => (
          <div class="bg-bg-card border border-white/5 rounded-sm p-6 hover:border-blue-brand/25 transition-colors group">
            <div class="text-3xl mb-3">{load.icon}</div>
            <h3 class="font-heading font-bold text-xl text-text-primary mb-2 group-hover:text-blue-brand transition-colors">{load.title}</h3>
            <p class="text-text-muted text-sm leading-relaxed">{load.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Temperature-sensitive note -->
  <section class="py-12 bg-bg">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="bg-navy/30 border border-blue-brand/20 rounded-sm p-6 lg:p-8 flex flex-col sm:flex-row gap-6 items-start">
        <div class="w-12 h-12 rounded-sm bg-blue-brand/10 border border-blue-brand/20 flex items-center justify-center shrink-0 text-2xl">
          🌡️
        </div>
        <div>
          <h3 class="font-heading font-bold text-xl text-text-primary mb-2">A Note on Temperature-Sensitive Cargo</h3>
          <p class="text-text-muted text-sm leading-relaxed max-w-3xl">
            Dry van trailers maintain ambient temperature — they do not heat or cool the trailer interior. For cargo that must remain within a specific temperature range (fresh or frozen food, pharmaceuticals, biologics), a refrigerated (reefer) trailer is required. If you're unsure whether your freight requires temperature control, our team can help you assess the right equipment. Contact us before booking if you have temperature concerns.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why BKE -->
  <section class="py-16 lg:py-20 bg-bg-secondary border-t border-white/5">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="mb-12">
        <span class="section-label block mb-3">Why BKE Logistics</span>
        <h2 class="font-heading font-bold text-3xl lg:text-4xl text-text-primary">
          Why Choose BKE for Dry Van
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {whyBKE.map(item => (
          <div class="flex gap-5 bg-bg-card border border-white/5 rounded-sm p-6 hover:border-blue-brand/20 transition-colors">
            <div class="w-10 h-10 rounded-sm bg-blue-brand/10 border border-blue-brand/20 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-blue-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-bold text-xl text-text-primary mb-2">{item.title}</h3>
              <p class="text-text-muted text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <QuoteSection
    headline="Ready to Ship Dry Van?"
    subtext="Share your shipment details — origin, destination, freight dimensions, weight, and desired pickup date. Our team will provide a competitive, no-obligation dry van rate quickly."
    ctaLabel="Get a Dry Van Quote"
  />
</BaseLayout>
