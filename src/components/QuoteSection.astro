---
interface Props {
  headline?: string;
  subtext?: string;
  ctaLabel?: string;
}

const {
  headline = 'Ready to Move Your Freight?',
  subtext = 'Get a competitive rate quote within hours. Our dispatch team is standing by 24/7 to discuss your shipment requirements and provide a transparent, no-obligation price.',
  ctaLabel = 'Request a Free Quote',
} = Astro.props;
---

<section class="relative py-20 lg:py-28 overflow-hidden" style="background: linear-gradient(160deg, #0b1220 0%, #0d1e3a 50%, #081c3e 100%);">
  <!-- Radial glow spotlights -->
  <div class="absolute top-[-30%] left-[20%] w-[500px] h-[500px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(23,105,212,0.15) 0%, transparent 65%);" aria-hidden="true"></div>
  <div class="absolute bottom-[-20%] right-[10%] w-[400px] h-[400px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(13,43,92,0.4) 0%, transparent 65%);" aria-hidden="true"></div>

  <!-- Large decorative text -->
  <div
    class="absolute right-0 top-1/2 -translate-y-1/2 font-heading font-black text-[200px] leading-none text-white/[0.03] select-none pointer-events-none"
    aria-hidden="true"
  >
    BKE
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-5 lg:px-8">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 mb-6">
        <div class="w-8 h-px bg-blue-brand"></div>
        <span class="section-label">Get Started Today</span>
        <div class="w-8 h-px bg-blue-brand"></div>
      </div>

      <h2 class="font-heading font-black text-5xl lg:text-6xl xl:text-7xl text-white leading-[1.0] mb-6">
        {headline}
      </h2>

      <p class="text-text-muted text-lg leading-relaxed mb-10 max-w-2xl mx-auto">
        {subtext}
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/request-quote" class="btn-primary text-base px-10 py-4">
          {ctaLabel}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href="/contact" class="btn-secondary text-base px-10 py-4">
          Contact Dispatch
        </a>
      </div>

      <!-- Contact strip -->
      <div class="mt-12 pt-8 border-t border-white/[0.08] flex flex-col sm:flex-row items-center justify-center gap-8">
        <div class="flex items-center gap-3 text-text-muted">
          <svg class="w-4 h-4 text-blue-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <a href="tel:+14793510393" class="text-sm font-medium hover:text-blue-brand transition-colors">(479) 351-0393</a>
        </div>
        <div class="hidden sm:block w-px h-5 bg-white/10"></div>
        <div class="flex items-center gap-3 text-text-muted">
          <svg class="w-4 h-4 text-blue-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <a href="mailto:harveyr@bkelogistics.com" class="text-sm font-medium hover:text-blue-brand transition-colors">harveyr@bkelogistics.com</a>
        </div>
      </div>
    </div>
  </div>
</section>
