---
const stats = [
  { value: '500+', label: 'Loads Delivered' },
  { value: '48', label: 'States Covered' },
  { value: '10+', label: 'Years Experience' },
  { value: '24/7', label: 'Dispatch Available' },
];
---

<section class="bg-navy border-y border-blue-brand/20 relative overflow-hidden" aria-label="Company statistics">
  <!-- Stripe overlay -->
  <div
    class="absolute inset-0 opacity-20"
    style="background-image: repeating-linear-gradient(-45deg, transparent, transparent 12px, rgba(255,255,255,0.03) 12px, rgba(255,255,255,0.03) 24px);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-7xl mx-auto px-5 lg:px-8 py-10 lg:py-12">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-0 lg:divide-x lg:divide-white/10">
      {stats.map((stat, i) => (
        <div class={`text-center px-4 ${i > 0 ? 'lg:pl-8' : ''}`}>
          <div class="font-heading font-black text-4xl lg:text-5xl text-white mb-1">
            {stat.value}
          </div>
          <div class="text-text-muted text-sm font-medium tracking-wide uppercase">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
