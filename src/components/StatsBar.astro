---
const stats = [
  { value: '500+', label: 'Loads Delivered' },
  { value: '48', label: 'States Covered' },
  { value: '10+', label: 'Years Experience' },
  { value: '24/7', label: 'Dispatch Available' },
];
---

<section class="relative overflow-hidden border-y border-white/[0.06]" style="background: rgba(11,18,32,0.8); backdrop-filter: blur(12px);" aria-label="Company statistics">
  <!-- Radial glow instead of stripes -->
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 50% 100%, rgba(23,105,212,0.08) 0%, transparent 70%);" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-5 lg:px-8 py-10 lg:py-12">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-0 lg:divide-x lg:divide-white/[0.06]">
      {stats.map((stat, i) => (
        <div class={`text-center px-4 ${i > 0 ? 'lg:pl-8' : ''}`}>
          <div class="font-heading font-black text-4xl lg:text-5xl text-white mb-1">
            {stat.value}
          </div>
          <div class="text-text-muted text-sm font-medium tracking-wide uppercase">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
