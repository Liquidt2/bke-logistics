---
const corridors = [
  {
    region: 'Northeast Corridor',
    lanes: ['New York → Chicago', 'Boston → Philadelphia', 'New Jersey → Atlanta'],
  },
  {
    region: 'Southeast Freight',
    lanes: ['Atlanta → Miami', 'Charlotte → Nashville', 'Dallas → Houston'],
  },
  {
    region: 'Midwest & Plains',
    lanes: ['Chicago → Kansas City', 'Detroit → St. Louis', 'Minneapolis → Denver'],
  },
  {
    region: 'Southwest & West',
    lanes: ['Dallas → Phoenix', 'Los Angeles → Las Vegas', 'Seattle → Portland'],
  },
  {
    region: 'Cross-Country',
    lanes: ['Los Angeles → New York', 'Chicago → Los Angeles', 'Atlanta → Seattle'],
  },
  {
    region: 'Industrial Heartland',
    lanes: ['Cleveland → Pittsburgh', 'Columbus → Indianapolis', 'Louisville → Cincinnati'],
  },
];
---

<section class="py-16 lg:py-24 bg-bg-secondary" aria-label="Freight lanes we serve">
  <div class="max-w-7xl mx-auto px-5 lg:px-8">
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-12">
      <div>
        <span class="section-label block mb-3">Coverage</span>
        <h2 class="font-heading font-bold text-4xl lg:text-5xl text-text-primary leading-tight">
          Lanes We Serve
        </h2>
        <p class="text-text-muted mt-3 max-w-xl text-sm leading-relaxed">
          BKE Logistics runs regular freight lanes across the continental US. Whether you need consistent dedicated lanes or one-off shipments, we have coverage where you need it.
        </p>
      </div>
      <a href="/request-quote" class="btn-primary shrink-0">
        Check Your Lane
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-white/5 rounded-sm overflow-hidden">
      {corridors.map(corridor => (
        <div class="bg-bg-card p-6 hover:bg-navy/30 transition-colors duration-200 group">
          <div class="flex items-center gap-2 mb-4">
            <div class="w-2 h-2 bg-blue-brand rounded-full group-hover:shadow-blue-glow transition-shadow"></div>
            <h3 class="font-heading font-bold text-lg text-text-primary uppercase tracking-wide">
              {corridor.region}
            </h3>
          </div>
          <ul class="space-y-2">
            {corridor.lanes.map(lane => (
              <li class="flex items-center gap-2 text-text-muted text-sm">
                <svg class="w-3.5 h-3.5 text-blue-brand/60 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
                {lane}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <p class="text-text-subtle text-sm text-center mt-6">
      Don't see your lane? <a href="/contact" class="text-blue-brand hover:underline">Contact our dispatch team</a> — we operate beyond these corridors.
    </p>
  </div>
</section>
