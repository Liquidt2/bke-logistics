---
const regions = [
  'Northeast',
  'Southeast',
  'Midwest',
  'Southwest',
  'West Coast',
  'Cross-Country',
];
---

<section class="py-12 lg:py-16 bg-bg-secondary border-y border-white/[0.05]" aria-label="Coverage area">
  <div class="max-w-7xl mx-auto px-5 lg:px-8">
    <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-8">

      <!-- Left: heading -->
      <div class="shrink-0">
        <span class="section-label block mb-2">Coverage</span>
        <h2 class="font-heading font-bold text-3xl lg:text-4xl text-text-primary leading-tight">
          48-State Nationwide Coverage
        </h2>
        <p class="text-text-muted text-sm mt-2 max-w-sm leading-relaxed">
          Dedicated lanes and one-off shipments across the continental US — coast to coast, border to border.
        </p>
      </div>

      <!-- Right: region pills + CTA -->
      <div class="flex flex-col gap-4">
        <div class="flex flex-wrap gap-2">
          {regions.map(region => (
            <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-medium text-text-muted" style="background: rgba(23,105,212,0.08); border: 1px solid rgba(23,105,212,0.2);">
              <span class="w-1.5 h-1.5 rounded-full bg-blue-brand inline-block"></span>
              {region}
            </span>
          ))}
        </div>
        <div class="flex items-center gap-3">
          <a href="/request-quote" class="btn-primary">
            Check Your Lane
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a href="/contact" class="text-text-muted text-sm hover:text-blue-brand transition-colors">
            Don't see your lane? Contact us →
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
