---
const year = new Date().getFullYear();
---

<footer class="bg-bg-secondary border-t border-white/5">
  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">

      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-5">
          <img
            src="/logo.png"
            alt="BKE Logistics LLC"
            width="44"
            height="44"
            class="w-10 h-10 object-contain"
            onerror="this.style.display='none';"
          />
          <div>
            <div class="font-heading font-black text-xl text-white tracking-tight leading-none">BKE LOGISTICS</div>
            <div class="font-heading text-[9px] text-text-subtle tracking-[0.2em] uppercase mt-0.5">LLC.</div>
          </div>
        </a>
        <p class="text-text-muted text-sm leading-relaxed mb-6">
          Dependable freight solutions across 48 states. Flatbed, dry van, and full truckload specialists with 24/7 dispatch support.
        </p>
        <div class="flex gap-3">
          <!-- Social placeholders -->
          <a href="#" aria-label="LinkedIn" class="w-9 h-9 rounded-sm bg-navy/40 border border-white/10 flex items-center justify-center text-text-muted hover:text-blue-brand hover:border-blue-brand/40 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
          <a href="#" aria-label="Facebook" class="w-9 h-9 rounded-sm bg-navy/40 border border-white/10 flex items-center justify-center text-text-muted hover:text-blue-brand hover:border-blue-brand/40 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services Column -->
      <div>
        <h3 class="font-heading font-bold text-text-primary text-lg uppercase tracking-wider mb-5">Services</h3>
        <ul class="space-y-3">
          <li><a href="/freight-services" class="text-text-muted text-sm hover:text-blue-brand transition-colors">All Freight Services</a></li>
          <li><a href="/freight-services/flatbed" class="text-text-muted text-sm hover:text-blue-brand transition-colors">Flatbed Transport</a></li>
          <li><a href="/freight-services/dry-van" class="text-text-muted text-sm hover:text-blue-brand transition-colors">Dry Van Freight</a></li>
          <li><a href="/request-quote" class="text-text-muted text-sm hover:text-blue-brand transition-colors">Request a Quote</a></li>
        </ul>
      </div>

      <!-- Company Column -->
      <div>
        <h3 class="font-heading font-bold text-text-primary text-lg uppercase tracking-wider mb-5">Company</h3>
        <ul class="space-y-3">
          <li><a href="/about" class="text-text-muted text-sm hover:text-blue-brand transition-colors">About BKE Logistics</a></li>
          <li><a href="/industries" class="text-text-muted text-sm hover:text-blue-brand transition-colors">Industries Served</a></li>
          <li><a href="/blog" class="text-text-muted text-sm hover:text-blue-brand transition-colors">Blog & Updates</a></li>
          <li><a href="/contact" class="text-text-muted text-sm hover:text-blue-brand transition-colors">Contact Us</a></li>
        </ul>
      </div>

      <!-- Contact Column -->
      <div>
        <h3 class="font-heading font-bold text-text-primary text-lg uppercase tracking-wider mb-5">Contact</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-blue-brand mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <div>
              <div class="text-text-muted text-sm">(XXX) XXX-XXXX</div>
              <div class="text-text-subtle text-xs mt-0.5">24/7 Dispatch Line</div>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-blue-brand mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:dispatch@bkelogistics.com" class="text-text-muted text-sm hover:text-blue-brand transition-colors break-all">
              dispatch@bkelogistics.com
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-blue-brand mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <div class="text-text-muted text-sm">United States<br/><span class="text-text-subtle text-xs">Serving 48 States</span></div>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-text-subtle text-xs">
        &copy; {year} BKE Logistics LLC. All rights reserved.
      </p>
      <div class="flex items-center gap-5">
        <a href="/privacy-policy" class="text-text-subtle text-xs hover:text-text-muted transition-colors">Privacy Policy</a>
        <a href="/terms" class="text-text-subtle text-xs hover:text-text-muted transition-colors">Terms of Service</a>
        <span class="text-text-subtle text-xs">DOT Compliant · FMCSA Certified</span>
      </div>
    </div>
  </div>
</footer>
