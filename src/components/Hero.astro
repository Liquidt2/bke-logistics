---
interface Props {
  headline?: string;
  subheadline?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const {
  headline = 'Moving Freight.<br/>Building Trust.',
  subheadline = 'BKE Logistics LLC is an FMCSA-licensed freight broker connecting shippers with trusted carriers across 48 states. Flatbed, dry van, and specialty freight — handled with the expertise of someone who\'s been on both sides of the truck.',
  primaryCta = { label: 'Request a Quote', href: '/request-quote' },
  secondaryCta = { label: 'View Services', href: '/freight-services' },
} = Astro.props;
---

<section class="relative min-h-[92vh] flex items-center overflow-hidden bg-bg">
  <!-- Radial glow orbs — no stripes -->
  <div class="absolute top-[-10%] left-[-5%] w-[700px] h-[700px] rounded-full opacity-100 pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(23,105,212,0.14) 0%, transparent 65%);" aria-hidden="true"></div>
  <div class="absolute bottom-[-20%] right-[-10%] w-[600px] h-[600px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(13,43,92,0.5) 0%, transparent 65%);" aria-hidden="true"></div>
  <div class="absolute top-[30%] right-[15%] w-[350px] h-[350px] rounded-full opacity-60 pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(23,105,212,0.08) 0%, transparent 65%);" aria-hidden="true"></div>

  <!-- Subtle noise texture overlay -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.025]" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2240%22 height=%2240%22><circle cx=%2220%22 cy=%2220%22 r=%221%22 fill=%22white%22 opacity=%220.5%22/></svg>'); background-size: 40px 40px;" aria-hidden="true"></div>

  <!-- Left accent line -->
  <div class="absolute left-0 top-0 w-[2px] h-full bg-gradient-to-b from-transparent via-blue-brand/50 to-transparent" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-5 lg:px-8 py-24 lg:py-32 w-full">
    <div class="max-w-3xl">
      <!-- Label -->
      <div class="flex items-center gap-3 mb-8 animate-fade-up">
        <div class="w-8 h-px bg-blue-brand rounded-full"></div>
        <span class="section-label">FMCSA Licensed · MC# 1588065 · 48 States</span>
      </div>

      <!-- Headline -->
      <h1
        class="font-heading font-black text-6xl sm:text-7xl lg:text-8xl xl:text-9xl text-text-primary leading-[0.95] mb-8 animate-fade-up-delay-1"
        set:html={headline}
      />

      <!-- Subheadline -->
      <p class="text-text-muted text-lg sm:text-xl leading-relaxed max-w-2xl mb-12 animate-fade-up-delay-2">
        {subheadline}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 animate-fade-up-delay-3">
        <a href={primaryCta.href} class="btn-primary text-base px-9 py-4">
          {primaryCta.label}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href={secondaryCta.href} class="btn-secondary text-base px-9 py-4">
          {secondaryCta.label}
        </a>
      </div>

      <!-- Quick trust indicators -->
      <div class="flex flex-wrap items-center gap-6 mt-14 pt-10 border-t border-white/[0.06]">
        {[
          { icon: '✓', text: 'No Hidden Fees' },
          { icon: '✓', text: 'Direct Broker Access' },
          { icon: '✓', text: 'Real-Time Updates' },
          { icon: '✓', text: 'Surety Bonded' },
        ].map(item => (
          <div class="flex items-center gap-2">
            <span class="text-blue-brand text-sm font-bold">{item.icon}</span>
            <span class="text-text-muted text-sm font-medium">{item.text}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40" aria-hidden="true">
    <span class="text-text-muted text-[10px] tracking-[0.2em] uppercase">Scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-text-muted to-transparent"></div>
  </div>
</section>
