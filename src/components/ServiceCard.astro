---
interface Props {
  icon?: string;
  title: string;
  description: string;
  href: string;
  featured?: boolean;
}

const { icon, title, description, href, featured = false } = Astro.props;
---

<a
  href={href}
  class={`group card-service flex flex-col gap-5 ${featured ? 'border-blue-brand/30' : ''}`}
>
  {icon && (
    <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-2xl transition-all duration-300 group-hover:scale-110" style="background: rgba(23,105,212,0.1); border: 1px solid rgba(23,105,212,0.2);">
      {icon}
    </div>
  )}

  <div class="flex-1">
    <h3 class="font-heading font-bold text-2xl text-text-primary mb-2 group-hover:text-blue-brand transition-colors">
      {title}
    </h3>
    <p class="text-text-muted text-sm leading-relaxed">
      {description}
    </p>
  </div>

  <div class="flex items-center gap-2 text-blue-brand text-sm font-semibold mt-auto pt-2 border-t border-white/[0.06]">
    <span>Learn More</span>
    <svg
      class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1"
      fill="none" stroke="currentColor" viewBox="0 0 24 24"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
    </svg>
  </div>
</a>
