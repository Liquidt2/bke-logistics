---
const navLinks = [
  { label: 'Industries', href: '/industries' },
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
];

const serviceLinks = [
  { label: 'Flatbed', href: '/freight-services/flatbed' },
  { label: 'Dry Van', href: '/freight-services/dry-van' },
];

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="header-inner backdrop-blur-xl border-b border-white/[0.06]" style="background: rgba(8,13,26,0.92);">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="flex items-center justify-between h-20 lg:h-24">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group" aria-label="BKE Logistics LLC — Home">
          <img
            src="/logo.png"
            alt="BKE Logistics LLC"
            width="180"
            height="60"
            class="h-14 lg:h-16 w-auto object-contain"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          />
          <div class="logo-fallback hidden items-center gap-1">
            <span class="font-heading font-black text-2xl text-white tracking-tight">BKE</span>
            <div class="w-px h-6 bg-blue-brand/60 mx-1"></div>
            <span class="font-heading font-semibold text-xs text-text-muted tracking-widest uppercase leading-tight">
              LOGISTICS<br/>LLC.
            </span>
          </div>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-8" aria-label="Main navigation">
          <!-- Services Dropdown -->
          <div class="relative group">
            <button
              class="nav-link flex items-center gap-1.5 py-2"
              aria-haspopup="true"
              aria-expanded="false"
            >
              Services
              <svg class="w-3.5 h-3.5 text-text-subtle transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
              <div class="rounded-2xl shadow-card min-w-[180px] overflow-hidden" style="background: rgba(11,18,32,0.98); border: 1px solid rgba(255,255,255,0.08); backdrop-filter: blur(20px);">
                <a href="/freight-services" class="block px-5 py-3 text-sm text-text-muted hover:text-text-primary hover:bg-white/5 transition-colors border-b border-white/[0.06] font-medium">
                  All Services
                </a>
                {serviceLinks.map(link => (
                  <a href={link.href} class="block px-5 py-3 text-sm text-text-muted hover:text-text-primary hover:bg-white/5 transition-colors font-medium">
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          </div>

          {navLinks.map(link => (
            <a
              href={link.href}
              class={`nav-link py-2 ${currentPath.startsWith(link.href) ? 'text-text-primary' : ''}`}
            >
              {link.label}
            </a>
          ))}
        </nav>

        <!-- CTA + Mobile Toggle -->
        <div class="flex items-center gap-4">
          <a href="/request-quote" class="hidden sm:inline-flex btn-primary text-xs py-2.5 px-5">
            Request a Quote
          </a>

          <!-- Mobile hamburger -->
          <button
            id="mobile-menu-btn"
            class="lg:hidden flex flex-col gap-1.5 p-2 -mr-2"
            aria-label="Toggle mobile menu"
            aria-expanded="false"
          >
            <span class="hamburger-line block w-6 h-0.5 bg-text-primary transition-all duration-300"></span>
            <span class="hamburger-line block w-6 h-0.5 bg-text-primary transition-all duration-300"></span>
            <span class="hamburger-line block w-4 h-0.5 bg-text-primary transition-all duration-300"></span>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div
      id="mobile-menu"
      class="lg:hidden hidden border-t border-white/[0.06]"
      style="background: rgba(11,18,32,0.98);"
      aria-label="Mobile navigation"
    >
      <nav class="max-w-7xl mx-auto px-5 py-5 flex flex-col gap-1">
        <a href="/freight-services" class="block py-3 px-4 text-text-muted hover:text-text-primary hover:bg-white/5 rounded-xl transition-colors font-medium text-sm tracking-wide">All Services</a>
        {serviceLinks.map(link => (
          <a href={link.href} class="block py-3 px-6 text-text-muted hover:text-text-primary hover:bg-white/5 rounded-xl transition-colors text-sm">
            → {link.label}
          </a>
        ))}
        {navLinks.map(link => (
          <a href={link.href} class="block py-3 px-4 text-text-muted hover:text-text-primary hover:bg-white/5 rounded-xl transition-colors font-medium text-sm tracking-wide">
            {link.label}
          </a>
        ))}
        <div class="pt-3 border-t border-white/[0.06] mt-2">
          <a href="/request-quote" class="btn-primary w-full text-center">Request a Quote</a>
        </div>
      </nav>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16 lg:h-20" aria-hidden="true"></div>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const lines = document.querySelectorAll('.hamburger-line');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));

      if (!isOpen) {
        lines[0]?.classList.add('rotate-45', 'translate-y-2');
        lines[1]?.classList.add('opacity-0');
        lines[2]?.classList.add('-rotate-45', '-translate-y-2', 'w-6');
      } else {
        lines[0]?.classList.remove('rotate-45', 'translate-y-2');
        lines[1]?.classList.remove('opacity-0');
        lines[2]?.classList.remove('-rotate-45', '-translate-y-2', 'w-6');
      }
    });
  }

  // Header scroll effect
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (header) {
      if (window.scrollY > 50) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    }
  }, { passive: true });
</script>

<style>
  .logo-text-group {
    display: none;
  }

  #site-header .header-inner {
    transition: box-shadow 0.3s ease;
  }

  #site-header.scrolled .header-inner {
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
  }
</style>
