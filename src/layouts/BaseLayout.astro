---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description = 'BKE Logistics LLC — Reliable flatbed and dry van freight services across 48 states. FMCSA certified, DOT compliant, 24/7 dispatch.',
  ogImage = '/og-default.jpg',
  canonical,
} = Astro.props;

const siteUrl = 'https://bkelogistics.com';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Primary Meta -->
    <title>{title} | BKE Logistics LLC</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${title} | BKE Logistics LLC`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:site_name" content="BKE Logistics LLC" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | BKE Logistics LLC`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Schema.org -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "TransportationCompany",
        "name": "BKE Logistics LLC",
        "url": "https://bkelogistics.com",
        "description": "Reliable flatbed and dry van freight services across 48 states.",
        "email": "dispatch@bkelogistics.com",
        "areaServed": "US",
        "serviceType": ["Flatbed Freight", "Dry Van Freight", "Full Truckload"]
      }
    </script>

    <slot name="head" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
